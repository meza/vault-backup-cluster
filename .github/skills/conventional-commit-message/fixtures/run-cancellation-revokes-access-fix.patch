+export function getMagicLinksByRun(runId: string): MagicLink[] {
+  return Array.from(magicLinks.values()).filter((link) => link.runId === runId);
+}
+
 export function createMagicLink(link: MagicLink): MagicLink {
   magicLinks.set(link.id, link);
   return link;
@@ -49,3 +53,13 @@ export function createParticipant(participant: Participant): Participant {
   participants.set(participant.runId, [...existing, participant]);
   return participant;
 }
+
+export function deleteParticipantsByRun(runId: string): void {
+  participants.delete(runId);
+}
+
+export function deleteMagicLinksByRun(runId: string): void {
+  for (const link of getMagicLinksByRun(runId)) {
+    magicLinks.delete(link.id);
+  }
+}
