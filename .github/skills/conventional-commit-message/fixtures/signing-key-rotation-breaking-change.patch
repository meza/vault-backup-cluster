diff --git a/src/config.ts b/src/config.ts
index 7df62b4..4a41807 100644
--- a/src/config.ts
+++ b/src/config.ts
@@ -6,8 +6,82 @@ const required = (key: string): string => {
   return value;
 };
 
+export interface HmacSigningKey {
+  id: string;
+  secret: string;
+}
+
+export interface HmacKeyConfig {
+  activeKey: HmacSigningKey;
+  activeKeyId: string;
+  keys: HmacSigningKey[];
+  keysById: Record<string, HmacSigningKey>;
+}
+
+function parseSigningKeys(raw: string): HmacSigningKey[] {
+  let parsed: unknown;
+
+  try {
+    parsed = JSON.parse(raw);
+  } catch {
+    throw new Error('HMAC_SIGNING_KEYS must be valid JSON');
+  }
+
+  if (!Array.isArray(parsed) || parsed.length === 0) {
+    throw new Error('HMAC_SIGNING_KEYS must be a non-empty JSON array');
+  }
+
+  return parsed.map((entry, index) => {
+    if (!entry || typeof entry !== 'object') {
+      throw new Error(`HMAC_SIGNING_KEYS[${index}] must be an object`);
+    }
+
+    const id = 'id' in entry ? entry.id : undefined;
+    const secret = 'secret' in entry ? entry.secret : undefined;
+
+    if (typeof id !== 'string' || id.trim() === '') {
+      throw new Error(`HMAC_SIGNING_KEYS[${index}].id must be a non-empty string`);
+    }
+
+    if (typeof secret !== 'string' || secret.trim() === '') {
+      throw new Error(`HMAC_SIGNING_KEYS[${index}].secret must be a non-empty string`);
+    }
+
+    return {
+      id,
+      secret,
+    };
+  });
+}
+
+function loadHmacConfig(): HmacKeyConfig {
+  const activeKeyId = required('HMAC_ACTIVE_KEY_ID');
+  const keys = parseSigningKeys(required('HMAC_SIGNING_KEYS'));
+  const keysById: Record<string, HmacSigningKey> = {};
+
+  for (const key of keys) {
+    if (keysById[key.id]) {
+      throw new Error(`HMAC_SIGNING_KEYS contains duplicate key id: ${key.id}`);
+    }
+
+    keysById[key.id] = key;
+  }
+
+  const activeKey = keysById[activeKeyId];
+  if (!activeKey) {
+    throw new Error(`HMAC_ACTIVE_KEY_ID references unknown key id: ${activeKeyId}`);
+  }
+
+  return {
+    activeKey,
+    activeKeyId,
+    keys,
+    keysById,
+  };
+}
+
 export const config = {
-  hmacSecret: required('HMAC_SECRET'),
+  hmac: loadHmacConfig(),
   port: parseInt(process.env.PORT ?? '3000', 10),
   nodeEnv: process.env.NODE_ENV ?? 'development',
 };
