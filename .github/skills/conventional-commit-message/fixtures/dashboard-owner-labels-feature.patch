diff --git a/src/lib/dashboard-projects.ts b/src/lib/dashboard-projects.ts
new file mode 100644
index 0000000..7b962c0
--- /dev/null
+++ b/src/lib/dashboard-projects.ts
@@ -0,0 +1,19 @@
+import { db } from '@/lib/db'
+import { formatOwnerLabel } from '@/lib/owner-label'
+import type { DashboardProject } from '@/lib/types'
+
+export async function getDashboardProjects(): Promise<DashboardProject[]> {
+  const projects = await db.project.findMany({
+    include: {
+      owner: true,
+    },
+    orderBy: { createdAt: 'desc' },
+  })
+
+  return projects.map((project) => ({
+    id: project.id,
+    name: project.name,
+    createdAt: project.createdAt,
+    ownerLabel: formatOwnerLabel(project.owner),
+  }))
+}
