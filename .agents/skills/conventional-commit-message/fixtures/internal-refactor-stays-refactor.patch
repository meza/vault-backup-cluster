new file mode 100644
index 0000000..1969bdc
--- /dev/null
+++ b/src/data/users.ts
@@ -0,0 +1,84 @@
+export type UserRole = 'admin' | 'member' | 'viewer';
+
+interface StoredUser {
+  id: string;
+  email: string;
+  role: UserRole;
+  name: string;
+  passwordHash: string;
+}
+
+export interface SafeUser {
+  id: string;
+  email: string;
+  name: string;
+}
+
+export interface UserProfile extends SafeUser {
+  role: UserRole;
+}
+
+export interface AuthenticatedUser {
+  id: string;
+  email: string;
+  role: UserRole;
+}
+
+const VALID_PASSWORD = 'correct-horse-battery-staple';
+
+const USERS: StoredUser[] = [
+  {
+    id: 'user-001',
+    email: 'alice@example.com',
+    role: 'admin',
+    name: 'Alice',
+    passwordHash: '$2b$10$examplehash',
+  },
+  {
+    id: 'user-002',
+    email: 'bob@example.com',
+    role: 'member',
+    name: 'Bob',
+    passwordHash: '$2b$10$examplehash',
+  },
+];
+
+function toUserProfile(user: StoredUser): UserProfile {
+  return {
+    id: user.id,
+    email: user.email,
+    role: user.role,
+    name: user.name,
+  };
+}
+
+export function listSafeUsers(): SafeUser[] {
+  return USERS.map(({ id, email, name }) => ({ id, email, name }));
+}
+
+export function findUserProfileById(id: string): UserProfile | undefined {
+  const user = USERS.find(candidate => candidate.id === id);
+  return user ? toUserProfile(user) : undefined;
+}
+
+export function hasUser(id: string): boolean {
+  return USERS.some(user => user.id === id);
+}
+
+export function validateUserCredentials(email: string, password: string): AuthenticatedUser | null {
+  const user = USERS.find(candidate => candidate.email === email);
+  if (!user) {
+    return null;
+  }
+
+  // In prod: bcrypt.compareSync(password, user.passwordHash)
+  if (password !== VALID_PASSWORD) {
+    return null;
+  }
+
+  return {
+    id: user.id,
+    email: user.email,
+    role: user.role,
+  };
+}
