diff --git a/src/lib/token-codec.ts b/src/lib/token-codec.ts
new file mode 100644
index 0000000..8d3cc26
--- /dev/null
+++ b/src/lib/token-codec.ts
@@ -0,0 +1,34 @@
+export interface SignedTokenParts {
+  header: string;
+  body: string;
+  signature: string;
+}
+
+export const HMAC_ALGORITHM = 'sha256';
+export const TOKEN_VERSION = 'v1';
+
+export function encodeTokenSegment(value: unknown): string {
+  return Buffer.from(JSON.stringify(value)).toString('base64url');
+}
+
+export function decodeTokenSegment<T>(value: string): T {
+  return JSON.parse(Buffer.from(value, 'base64url').toString('utf8')) as T;
+}
+
+export function createTokenHeader(): string {
+  return encodeTokenSegment({ alg: HMAC_ALGORITHM, ver: TOKEN_VERSION });
+}
+
+export function splitSignedToken(token: string): SignedTokenParts | null {
+  const parts = token.split('.');
+  if (parts.length !== 3) {
+    return null;
+  }
+
+  const [header, body, signature] = parts;
+  return { header, body, signature };
+}
+
+export function createSigningInput(parts: Pick<SignedTokenParts, 'header' | 'body'>): string {
+  return `${parts.header}.${parts.body}`;
+}
diff --git a/src/lib/token-signature.ts b/src/lib/token-signature.ts
new file mode 100644
index 0000000..c1456ee
--- /dev/null
+++ b/src/lib/token-signature.ts
@@ -0,0 +1,21 @@
+import crypto from 'crypto';
+import { config } from '../config';
+import { HMAC_ALGORITHM } from './token-codec';
+
+export function signTokenInput(data: string): string {
+  return crypto
+    .createHmac(HMAC_ALGORITHM, config.hmacSecret)
+    .update(data)
+    .digest('base64url');
+}
+
+export function signaturesMatch(signature: string, expectedSignature: string): boolean {
+  const signatureBuffer = Buffer.from(signature);
+  const expectedBuffer = Buffer.from(expectedSignature);
+
+  if (signatureBuffer.length !== expectedBuffer.length) {
+    return false;
+  }
+
+  return crypto.timingSafeEqual(signatureBuffer, expectedBuffer);
+}
